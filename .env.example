# PostgreSQL (local installation)
DATABASE_URL="postgresql://postgres:admin@localhost:5432/Testforge?schema=public"

# Encryption key for credential storage (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
ENCRYPTION_KEY="your-64-character-hex-string-here"

# =============================================================================
# AI Provider Configuration
# =============================================================================

# AI Provider Toggle: "openai" | "azureopenai"
AI_PROVIDER="openai"

# --- OpenAI (when AI_PROVIDER=openai) ---
OPENAI_API_KEY=
OPENAI_MODEL="gpt-4o"

# --- Azure OpenAI via WSO2 (when AI_PROVIDER=azureopenai) ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_EMBEDDING_ENDPOINT=
AZURE_OPENAI_API_VERSION="2024-02-15-preview"
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
WSO2_CONSUMER_KEY=
WSO2_CONSUMER_SECRET=
WSO2_TOKEN_URL=
